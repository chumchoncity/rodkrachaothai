<div class="min-h-screen">
    <section class="relative text-center min-h-[40vh] md:min-h-[40vh] w-full">
        <div class="absolute inset-0 max-w-7xl mx-auto p-6 flex flex-col z-10 h-full">
            <div class="text-gray-100 font-[kanit] p-4">
                <h2 class="text-3xl md:text-5xl font-semibold text-start p-1">เครื่องจักร</h2>
                <h2 class="text-2xl md:text-3xl font-semibold text-start p-1 text-orange-400">MACHINES</h2>
                <p class="text-lg md:text-xl text-start p-1 mt-2">รถกระเช้า เอ็กซ์ลิฟท์ บูมลิฟท์</p>
                <p class="text-lg md:text-xl text-start p-1">ตอบโจทย์ทุกงาน ในที่สูง</p>

            </div>
        </div>
        

        
        <div
            class="absolute inset-0 bg-cover bg-right md:bg-center"
            style="background-image: url('/images/bg-hero.png');" alt="รถกระเช้าไทย">
        </div>

        
        <div
            class="absolute inset-0 bg-gradient-to-r from-slate-900 via-blue-900/80 to-sky-700/20">
        </div>
        
    </section>


    <section class="w-full bg-white font-[kanit] text-gray-700">
        <div class="max-w-7xl mx-auto p-6">
            <h2 class="text-2xl font-semibold py-6">รายการเครื่องจักรทั้งหมด</h2>
            <div class="w-full rounded p-4 border-2 border-slate-300 shadow">
                <form action="/machines" method="GET" class="grid grid-cols-1 md:grid-cols-4 gap-3">

                    <select name="brand_name" class="border-2 border-slate-200 rounded px-4 py-2">
                        <option value="">
                            ทุกแบรนด์
                        </option>

                        <option value="Genie"
                            <%= filters.brand_name === "Genie" ? "selected" : "" %>>
                            Genie
                        </option>

                        <option value="JLG"
                            <%= filters.brand_name === "JLG" ? "selected" : "" %>>
                            JLG
                        </option>

                    </select>

                    <select name="type_name" class="border-2 border-slate-200 rounded px-4 py-2">

                        <option value="">ทุกประเภท</option>

                        <option value="บูมลิฟท์"
                            <%= filters.type_name === "บูมลิฟท์" ? "selected" : "" %>>
                            บูมลิฟท์
                        </option>

                        <option value="เอ็กซ์ลิฟท์"
                            <%= filters.type_name === "เอ็กซ์ลิฟท์" ? "selected" : "" %>>
                            เอ็กซ์ลิฟท์
                        </option>

                    </select>

                    <input
                        type="number"
                        name="working_height"
                        placeholder="ความสูงขั้นต่ำ"
                        value="<%= filters.working_height %>"
                        class="border-2 border-slate-200 rounded px-4 py-2 placeholder:text-gray-700">

                    <div class="flex justify-end mt-6 md:mt-0">
                        <button type="submit" class="px-6 py-2 w-full md:min-w-[80px] rounded bg-blue-800 text-gray-100 grid grid-cols-[24px_1fr] w-full items-center">
                            <span>
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-search"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M3 10a7 7 0 1 0 14 0a7 7 0 1 0 -14 0" /><path d="M21 21l-6 -6" /></svg>
                            </span>
                            ค้นหา
                        </button>
                    </div>

                </form>
            </div>
            
            
                <div class="w-full grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 py-10">
                    <% machines.forEach(machine => { %>
                    <div class="grid grid-rows-2 rounded border-2 border-slate-300 shadow-md">
                        <div class="p-4">
                            <img src="<%= machine.image_url %>" alt="<%= machine.model %>" class="w-full object-contain h-48 p-4">
                            
                        </div>
                        <div class="p-4 bg-slate-200">
                            <div>
                                <h2 class="tracking-wide text-xl font-semibold"><%= machine.type_name %> <%= machine.platform_height %> เมตร</h2>
                                <p class="tracking-wide font-light"><%= machine.brand_name %> <%= machine.model %></p>
                            </div>
                            <div class="my-4">
                                <p class="">ความสูงทำงาน <%= machine.working_height %> เมตร</p>
                                <p class="">รับน้ำหนัก <%= machine.capacity_load %> กิโลกรัม</p>
                            </div>
                            <div class="flex justify-center mt-4">
                                <a href="/machines/<%= machine.slug %>" class="px-4 py-2 bg-blue-800 rounded shadow hover:bg-blue-700 text-gray-100">
                                ดูรายละเอียด
                            </a>
                            </div>

                        </div>

                    </div>
                    <% }) %>
                </div>

            
            
        </div>     
    </section>






    

</div>