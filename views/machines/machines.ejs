<div class="min-h-screen">
    <section class="relative text-center min-h-[40vh] md:min-h-[60vh] w-full">
        <div class="absolute inset-0 max-w-7xl mx-auto p-6 flex flex-col z-10 h-full">
            <div class="text-gray-100 font-[kanit] p-4">
                <h2 class="text-3xl md:text-5xl font-semibold text-start p-1">เครื่องจักร</h2>
                <h2 class="text-2xl md:text-3xl font-semibold text-start p-1 text-orange-400">MACHINES</h2>
                <p class="text-xl md:text-2xl text-start p-1 mt-6">รถกระเช้า เอ็กซ์ลิฟท์ บูมลิฟท์</p>
                <p class="text-xl md:text-2xl text-start p-1">ตอบโจทย์ทุกงาน ในที่สูง</p>

            </div>
            <div class="absolute left-10 bottom-10 text-gray-100 flex gap-2 md:gap-6 z-10 font-[kanit]">
                <span class="flex flex-col items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-shield-check border-2 border-gray-100 rounded-full p-2"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M11.46 20.846a12 12 0 0 1 -7.96 -14.846a12 12 0 0 0 8.5 -3a12 12 0 0 0 8.5 3a12 12 0 0 1 -.09 7.06" /><path d="M15 19l2 2l4 -4" /></svg>
                    <p class="text-sm md:text-md">ปลอดภัย<br>ได้มาตรฐาน</p>
                </span>

                <span class="flex flex-col items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-truck-delivery border-2 border-gray-100 rounded-full p-2"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M5 17a2 2 0 1 0 4 0a2 2 0 1 0 -4 0" /><path d="M15 17a2 2 0 1 0 4 0a2 2 0 1 0 -4 0" /><path d="M5 17h-2v-4m-1 -8h11v12m-4 0h6m4 0h2v-6h-8m0 -5h5l3 5" /><path d="M3 9l4 0" /></svg>
                    <p class="text-sm md:text-md">บริการ<br>ทั่วประเทศ</p>
                </span>

                <span class="flex flex-col items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-tool border-2 border-gray-100 rounded-full p-2"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M7 10h3v-3l-3.5 -3.5a6 6 0 0 1 8 8l6 6a2 2 0 0 1 -3 3l-6 -6a6 6 0 0 1 -8 -8l3.5 3.5" /></svg>
                    <p class="text-sm md:text-md">ทีมช่าง<br>มืออาชีพ</p>
                </span>

                <span class="flex flex-col items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-car-lifter border-2 border-gray-100 rounded-full p-2"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M7 21l10 -7l-10 -7" /><path d="M17 7l-10 7l10 7" /><path d="M20 7h-16a1 1 0 0 1 -1 -1v-2a1 1 0 0 1 1 -1h16a1 1 0 0 1 1 1v2a1 1 0 0 1 -1 1" /><path d="M3 21h18" /></svg>
                    <p class="text-sm md:text-md">เช่า รายวัน<br>รายเดือน</p>
                </span>
            </div>
        </div>
        

        
        <div
            class="absolute inset-0 bg-cover bg-right md:bg-center"
            style="background-image: url('/images/bg-hero.png');" alt="รถกระเช้าไทย">
        </div>

        
        <div
            class="absolute inset-0 bg-gradient-to-r from-slate-900/99 via-blue-900/85 to-sky-700/20">
        </div>
        
    </section>


    <section class="w-full bg-white font-[kanit] text-gray-700">
        <div class="max-w-7xl mx-auto px-6">
            <h2 class="text-2xl font-semibold pt-6">รายการเครื่องจักรทั้งหมด</h2>
            
            
                <div class="w-full grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 py-10">
                    <% machineAll.forEach(machine => { %>
                    <div class="grid grid-rows-2 rounded border-2 border-slate-300 shadow-md">
                        <div class="p-4">
                            <img src="<%= machine.image_url %>" alt="<%= machine.model %>" class="w-full object-contain h-48 p-4">
                            
                        </div>
                        <div class="p-4 bg-slate-200">
                            <div>
                                <h2 class="tracking-wide text-xl font-semibold"><%= machine.type_name %> <%= machine.platform_height %> เมตร</h2>
                                <p class="tracking-wide font-light"><%= machine.brand_name %> <%= machine.model %></p>
                            </div>
                            <div class="my-4">
                                <p class="">ความสูงทำงาน <%= machine.working_height %> เมตร</p>
                                <p class="">รับน้ำหนัก <%= machine.capacity_load %> กิโลกรัม</p>
                            </div>
                            <div class="flex justify-center mt-4">
                                <a href="/machines/<%= machine.slug %>" class="px-4 py-2 bg-blue-800 rounded shadow hover:bg-blue-700 text-gray-100">
                                ดูรายละเอียด
                            </a>
                            </div>

                        </div>

                    </div>
                    <% }) %>
                </div>

            
            
        </div>     
    </section>






    

</div>